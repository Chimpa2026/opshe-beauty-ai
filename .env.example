# ══════════════════════════════════════════════════
# OPSHE Beauty AI — Environment Variables
# Copy this file to .env and fill in values
# ══════════════════════════════════════════════════

# App
DEBUG=false
SECRET_KEY=change-this-to-a-secure-random-string

# Server
HOST=0.0.0.0
PORT=8000

# Database
# Development (SQLite):
DATABASE_URL=sqlite:///./opshe.db

# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/opshe_db

# Uploads
MAX_IMAGE_SIZE_MB=10
